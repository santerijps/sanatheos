{
  "name": "bible-app",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run --watch src/server.ts",
    "build:static": "bun run scripts/build-static.ts",
    "lint": "oxlint src/ tests/ scripts/",
    "lint:fix": "oxlint --fix src/ tests/ scripts/",
    "fmt": "oxfmt --check src/ tests/ scripts/",
    "fmt:fix": "oxfmt src/ tests/ scripts/",
    "test:e2e": "bunx playwright test",
    "test:coverage": "bun test --coverage",
    "validate": "bunx tsc --noEmit",
    "download-translation": "python scripts/bible-gateway.py",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "@types/node": "^25.5.1",
    "@types/qrcode": "^1.5.6",
    "lefthook": "^2.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
